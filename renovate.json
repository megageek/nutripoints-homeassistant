{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^contract-version\\.txt$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+) extractVersion=(?<extractVersion>\\S+)\\s+(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["megageek/nutripoints"],
      "addLabels": ["contract-update"],
      "automerge": false
    }
  ]
}
